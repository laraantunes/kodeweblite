{
  "name": "KodeWeb Lite",
  "short_name": "KodeWeb Lite",
  "description": "Uma IDE completa direto no navegador do seu celular",
  "start_url": "./",
  "display": "standalone",
  "background_color": "#0b0114",
  "theme_color": "#140523",
  "icons": [
    {
      "src": "logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "share_target.php",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "shared_file",
          "accept": [
            "text/*", 
            "image/*", 
            "application/pdf",
            ".pdf",
            ".txt",
            ".json",
            ".js",
            ".ts",
            ".css",
            ".html",
            ".php",
            ".sql",
            ".md",
            ".xml",
            ".csv",
            ".yaml",
            ".yml",
            ".env",
            ".sh"
          ]
        }
      ]
    }
  }
}